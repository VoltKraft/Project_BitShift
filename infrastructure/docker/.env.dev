# Dev defaults — safe to commit; for local docker compose use only.
# Do NOT reuse these values in any reachable environment.

# --- Postgres ---
POSTGRES_USER=chronos
POSTGRES_PASSWORD=chronos_dev
POSTGRES_DB=chronos

# --- API ---
SESSION_SECRET=dev_session_secret_do_not_use_in_prod
COOKIE_NAME=chronos_session
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
SESSION_MAX_AGE_SECONDS=28800
LOG_LEVEL=debug

# --- Worker ---
JOB_POLL_INTERVAL_SECONDS=5

# --- Traefik / public host ---
PUBLIC_HOST=chronos.localhost
